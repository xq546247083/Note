var isIE = /msie/i.test(navigator.userAgent);

function gID(id){return document.getElementById(id);}

//婕傛诞
//鍙傛暟锛氬眰ID锛岃褰曚笂娆℃粴鍔ㄤ綅缃紙榛樿鍙互涓虹┖锛岄€掑綊浣跨敤锛�
function ScrollDiv(id,pScrollY){ 
	//var ScrollY = document.documentElement.scrollTop ? document.documentElement.scrollTop : document.body.scrollTop;
	var ScrollY = document.documentElement.scrollTop || document.body.scrollTop; //鍏煎澶勭悊
	if (pScrollY ==null) { pScrollY=0; }

	var moveTop = .1 * (ScrollY - pScrollY); //鍙皟鏁寸Щ鍔ㄩ€熷害
	moveTop = (moveTop > 0) ? Math.ceil(moveTop) : Math.floor(moveTop);
	gID(id).style.top = parseInt(gID(id).style.top) + moveTop + "px";

	pScrollY = pScrollY + moveTop; 
	setTimeout("ScrollDiv('"+id+"',"+pScrollY+");",50); //鍙皟鏁存粴鍔ㄥ悗鐨勫弽鏄犻€熷害
}


//澧炲姞浜嬩欢鍔ㄤ綔锛屼笉鍐茬獊鍘熸潵鐨勪簨浠�
//鍙傛暟锛屽璞★紝浜嬩欢鍚嶇О锛堝甫on锛夛紝浜嬩欢瀹氫箟锛堝鏋滆甯﹀弬鏁帮紝鍒欒function(){eventFunc("")}杩欐牱浼犻€掑弬鏁帮級
function addObjEvent(obj,eventName,eventFunc){
	if (obj.attachEvent){ //IE
		obj.attachEvent(eventName,eventFunc);
	}else if (obj.addEventListener){ //FF Gecko / W3C
		var eventName2 = eventName.toString().replace(/on(.*)/i,'$1'); //姝ｅ垯杩囨护绗�1涓猳n
		obj.addEventListener(eventName2,eventFunc, false); //fslse涓哄€掑簭鎵ц浜嬩欢
	}else{
		obj[eventName] = eventFunc;
	}
}


//绉婚櫎浜嬩欢鍔ㄤ綔
//鍙傛暟锛屽璞★紝浜嬩欢鍚嶇О锛堝甫on锛夛紝浜嬩欢瀹氫箟锛堝鏋滆甯﹀弬鏁帮紝鍒欒function(){eventFunc("")}杩欐牱浼犻€掑弬鏁帮級
function delObjEvent(obj,eventName,eventFunc){
	if (obj.detachEvent) { // IE
		obj.detachEvent(eventName,eventFunc);
	}else if (obj.removeEventListener){ //FF Gecko / W3C
		var eventName2 = eventName.toString().replace(/on(.*)/i,'$1'); //姝ｅ垯杩囨护绗�1涓猳n
		obj.removeEventListener(eventName2,eventFunc, false); //fslse涓哄€掑簭鎵ц浜嬩欢
	}else{
		obj[eventName] = null;
	}
}


